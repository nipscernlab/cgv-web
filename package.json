{
  "name": "cgv-web",
  "version": "1.0.0",
  "description": "CGV Web — browser-based 3D viewer for the ATLAS Tile Calorimeter (TileCal) at CERN. Renders .root geometry compiled to .glb via Three.js + WebGL, and overlays live event data (cells, clusters, tracks) parsed from JiveXML by a Rust/WASM ATLAS-ID decoder.",
  "keywords": [
    "atlas",
    "cern",
    "lhc",
    "tilecal",
    "calorimeter",
    "particle-physics",
    "visualization",
    "threejs",
    "webgl",
    "wasm",
    "jivexml",
    "nipscern"
  ],
  "homepage": "https://github.com/nipscernlab/cgv-web#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nipscernlab/cgv-web.git"
  },
  "bugs": {
    "url": "https://github.com/nipscernlab/cgv-web/issues"
  },
  "license": "NIPSCERN-NC-1.0",
  "author": "Luciano Manhães de Andrade Filho <luciano.ma.filho@gmail.com>",
  "contributors": [
    "Chrysthofer Arthur Amaro Afonso <chrysthofer.afonso@estudante.ufjf.br>"
  ],
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start":                 "python serve.py",
    "dev":                   "npm run fetch:geometry && npm run fetch:samples && python serve.py",
    "build":                 "build.bat",
    "build:geom":            "node tools/setup/setup.mjs",
    "deploy":                "node tools/scripts/deploy.mjs",
    "fetch:geometry":        "node tools/scripts/fetch-geometry.mjs",
    "fetch:geometry:source": "node tools/scripts/fetch-geometry.mjs --with-source",
    "fetch:samples":         "node tools/scripts/fetch-samples.mjs",
    "lint":         "eslint \"public/js/**/*.js\" \"tools/setup/**/*.mjs\" \"tests/**/*.mjs\"",
    "lint:fix":     "eslint --fix \"public/js/**/*.js\" \"tools/setup/**/*.mjs\" \"tests/**/*.mjs\"",
    "format":       "prettier --write \"public/js/**/*.js\" \"tools/setup/**/*.mjs\" \"tests/**/*.mjs\" \"public/css/**/*.css\" public/index.html",
    "format:check": "prettier --check \"public/js/**/*.js\" \"tools/setup/**/*.mjs\" \"tests/**/*.mjs\" \"public/css/**/*.css\" public/index.html",
    "test":         "vitest run",
    "test:watch":   "vitest",
    "typecheck":    "tsc --noEmit"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "jsroot": "^7.10.3",
    "three": "^0.162.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.12.0",
    "@types/three": "^0.162.0",
    "prettier": "^3.4.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
